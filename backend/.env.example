# Avatar Studio backend (LP-MuseTalk) — maxfiy kalitlar namunasi.
# Bu faylni `.env` nomi bilan nusxalang va o'z qiymatlaringizni yozing.
# .env ni hech qachon ommaga (git/bundle) bermang!

# Admin panel paroli (/admin login). O'rnatmasangiz standart "admin" — ALMASHTIRING!
ADMIN_PASSWORD=admin

# Joylashtirish muhiti: local (standart) | production.
# production qo'ysangiz, standart "admin" parol yoki AUTH_DISABLED=1 bilan ishga
# tushish BLOKLANADI (server fail-fast) — har tashkilot instansiyasi uchun tavsiya.
APP_ENV=local

# OpenAI (GPT javoblar uchun)
OPENAI_API_KEY=sk-...

# Yandex SpeechKit (nigora / yulduz / filipp ... ovozlari — TTS uchun)
YX_API_KEY=...
YX_FOLDER_ID=...

# Yandex SpeechKit STT (real-time ovozli suhbat — gapirayotganda streaming tanish).
# /studio/realtime sahifasi uchun kerak. Bo'lmasa YX_API_KEY ishlatiladi.
YX_SPEECH_TO_SPEECH_KEY=...

# MuseTalk modellari boshqa joyda bo'lsa (ixtiyoriy):
# MT_DIR=/home/user/avatar_project/MuseTalk

# ── Observability / server (ixtiyoriy) ──
# LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=json           # json (prod, structured) | text (lokal, o'qishga qulay)

# ── Auth (lokal bitta foydalanuvchi) ──
# AUTH_DISABLED=0           # 1 → admin token tekshiruvini o'chirish (FAQAT sof lokal!)

# ── GPU / inference sozlamalari (ixtiyoriy, musetalk tomonidan o'qiladi) ──
# RT_GPU_SLOTS=2            # bir vaqtda parallel MuseTalk inference soni (1 GPU)
# MT_BATCH=16               # UNet batch hajmi
# VIDEO_ENCODER=h264_nvenc  # ffmpeg kodek (NVENC bo'lmasa libx264)

# ── Ma'lumotlar papkasi (ixtiyoriy — test/deploy izolyatsiyasi) ──
# DATA_DIR=/data/avatar_studio
