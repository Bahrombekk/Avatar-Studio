# Avatar Studio backend (LP-MuseTalk) — maxfiy kalitlar namunasi.
# Bu faylni `.env` nomi bilan nusxalang va o'z qiymatlaringizni yozing.
# .env ni hech qachon ommaga (git/bundle) bermang!

# OpenAI (GPT javoblar uchun)
OPENAI_API_KEY=sk-...

# Yandex SpeechKit (nigora / yulduz ovozlari uchun)
YX_API_KEY=...
YX_FOLDER_ID=...

# MuseTalk modellari boshqa joyda bo'lsa (ixtiyoriy):
# MT_DIR=/home/user/avatar_project/MuseTalk
