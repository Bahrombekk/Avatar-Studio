# ── Maxfiy kalitlar ──
.env
backend/.env
**/.env

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ── Node / Vite ──
node_modules/
frontend/node_modules/
frontend/dist/
*.log
npm-debug.log*

# ── Runtime / generatsiya (per-avatar/voice) ──
/tmp/lp_avatar_temp/
/tmp/lp_avatar_videos/
backend/data/avatars/*/events.jsonl
backend/data/avatars/*/voices/*/cache.json
backend/data/avatars/*/voices/*/videos/
# Eski tuzilma qoldiqlari (migratsiyadan keyin .bak)
backend/data/*.bak
backend/checkpoints/cache_index.json*
backend/static/videos/

# ── Eski monolit (backend/+frontend/ bilan almashtirilgan, repoga kerak emas) ──
/app/

# ── AI modellar (juda katta, alohida yuklanadi ~11 GB) ──
models/MuseTalk/models/
models/MuseTalk/results/
models/LivePortrait/pretrained_weights/

# ── Bundle qilingan conda muhiti (13 GB — GitHub'ga sig'maydi; wheels qoladi) ──
envs/avatar/
envs/*.tar
envs/*.tar.gz

# ── insightface buffalo_l onnx (166 MB w600k — GitHub limitidan oshadi) ──
backend/checkpoints/

# ── Per-avatar generatsiya artefaktlari (latents/mask/full_imgs/idle — katta, qayta yasaladi) ──
backend/data/avatars/*/artifact/
backend/data/avatars/*/idle.mp4
backend/data/avatars/*/source/
backend/data/avatars/*/vid_output/

# ── Og'ir binar formatlar (xavfsizlik to'ri) ──
*.pt
*.pth
*.onnx
*.safetensors
*.mp4

# ── OS / IDE ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Video Studiya render natijalari + zaxiralar (lokal, katta)
backend/data/renders/
*.mp4.bak

# Runtime statistika (har suhbat/renderdan keyin o'zgaradi — kuzatishga hojat yo'q)
backend/data/avatars/*/stats.json
